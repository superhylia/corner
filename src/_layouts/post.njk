---
layout: base
schema: BlogPosting
---

<div class="region" style="--region-space-top: var(--space-l-xl)" data-pagefind-body>
  <div class="wrapper flow prose">
    <h1>{{ title }}</h1>

      {% if image %}
      <!-- image -->
      {%
        imageKeys {
          "src": image,
          "alt": alt or "",
          "caption": description,
          "credit": credit,
          "loading": "eager"
        }
      %}
      {% endif %}

    <div class="meta | cluster gutter-xs-s">
      <!-- draft status -->
      {%- if draft -%}
        <span class="button" data-small-button data-button-variant="tertiary"> {% svg "misc/drafts" %} draft</span>
      {%- endif %}
      <!-- date -->
      {% set definedDate = date %} {% include "partials/date.njk" %}•
      <span>~{{ content | readingTime }} read</span>
      {% include 'partials/social-share.njk' %}
    </div>

    {% if series %}
      <div class="seriestop | cluster gutter-xs-s">
        <a class="button" data-small-button style="--button-bg: {{ seriesMeta[series].accentColor | safe }}; --button-color: {{ seriesMeta[series].headerTextColor | safe }}; width: 100%" href="/series/{{ series | slugify }}"> {% svg "misc/stack" %} Part of "{{ series }}" series</a>
      </div>
    {% endif %}

    {{ content | safe }}
    {% include 'partials/edit-on.njk' %}
    <hr>
    {% include 'partials/social-share-footer.njk' %}
    <div class="tags | cluster gutter-xs-s" style="margin-block-end: var(--flow-space, 1em);">
    {% if tags.length > 1 %}
      <!-- tags -->
      <span class="tags-label" style="font-size: var(--size-step-min-1);"> {% svg "misc/bookmark" %} Tags:</span> {% for tag in tags %}{% if tag != "posts" %}
        <a class="button" href="/tags/{{ tag | slugify }}/" data-small-button> #{{ tag }} </a>
      {% endif %}
      {% endfor %}
    {% endif %}
    </div>
  </div>


{% if series %}
  <div class="series | section">
      <section class="section__inner wrapper flow prose" style="padding-block-start: var(--space-l); --spot-color: {{ seriesMeta[series].accentColor | safe }}; color: {{ seriesMeta[series].headerTextColor | safe}};">
        {% svg "misc/stack" %}
        {% include 'partials/series-nav.njk' %}
      </section>
    </div>
{% endif%}

{% if bskyurl %}
  <div class="comments | section">
      <section class="section__inner wrapper flow prose" style="padding-block-start: var(--space-l); --spot-color: --color-bg; ">
        {% svg "misc/reply" %}
        {% include 'partials/bsky.njk' %}
      </section>
    </div>
{% endif%}

  <!--  h-card infos: https://indieweb.org/authorship -->
  <div hidden class="h-entry">
    <a class="u-url" href="{{ page.url | url | absoluteUrl(meta.url) }}">{{ title }}</a>
    <a class="p-name u-url" rel="author" href="{{ meta.url }}">{{ meta.author.name }}</a>
    <img
      eleventy:ignore
      class="u-author h-card"
      src="{{ meta.author.avatar | url | absoluteUrl(meta.url) }}"
      alt="{{ meta.author.name }}"
    />
  </div>
  
</div>
</article>



{%- css "local" -%}
  {%- include 'css/post.css' -%}
  {%- include 'css/footnotes.css' -%}
  {%- include 'css/table.css' -%}
{%- endcss -%}
