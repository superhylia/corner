{% set headingLevel = headingLevel | default("h2") %}
{% set definedDate = definedDate | default(item.date) %}

<custom-card clickable>
  <figure slot="image">
    <img src="{{ item.data.image }}" alt="{{ item.data.alt }}" loading="eager" decoding="sync">
  </figure>     
  <h2 slot="headline" class="text-step-2">
    <a href="{{ item.url | url }}">{{ item.data.title }}</a>
  </{{ headingLevel }}>
  <span slot="date"> {% include "partials/date.njk" %} </span>
  <div slot="content" webc:nokeep>{{ item.data.description | markdownFormat | safe }}</div>
</custom-card>

{% css "local" %}
  {% include "css/custom-card.css" %}
{% endcss %}
